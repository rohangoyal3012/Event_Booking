{
  "name": "eventbooking-backend",
  "version": "2.0.0",
  "description": "Production-grade Event Booking Platform API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "@sentry/node": "^7.99.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.5",
    "cloudinary": "^2.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^9.6.3",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "cookie-parser": "^1.4.6",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.7",
    "meilisearch": "^0.38.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.9",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.2",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.9.1",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "keywords": [],
  "author": "",
  "license": "MIT"
}
