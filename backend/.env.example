# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=9000

# ──────────────────────────────────────────────────────────────
# Database (Prisma)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# ──────────────────────────────────────────────────────────────
DATABASE_URL="mysql://eventuser:eventpassword@localhost:3306/eventbooking"

# ──────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────
REDIS_URL="redis://:redispassword@localhost:6379"

# ──────────────────────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────────────────────
JWT_SECRET="change_me_to_a_random_64_char_string"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ──────────────────────────────────────────────────────────────
# Cookie
# ──────────────────────────────────────────────────────────────
COOKIE_SECRET="change_me_to_another_random_string"

# ──────────────────────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ──────────────────────────────────────────────────────────────
# Razorpay
# Get from https://dashboard.razorpay.com
# ──────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# ──────────────────────────────────────────────────────────────
# Cloudinary
# Get from https://cloudinary.com/console
# ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ──────────────────────────────────────────────────────────────
# Email (SMTP)
# Example: Gmail App Password or Mailgun/SendGrid SMTP
# ──────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="\"EventBook\" <noreply@eventbook.com>"

# ──────────────────────────────────────────────────────────────
# Meilisearch
# ──────────────────────────────────────────────────────────────
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="masterkey_change_me"

# ──────────────────────────────────────────────────────────────
# Google OAuth (optional — for "Sign in with Google")
# ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
